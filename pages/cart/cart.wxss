.cart-page {
  width: 100%;
  min-height: 100vh;
  box-sizing: border-box;
  padding: 24rpx 28rpx 132rpx;
  overflow-x: hidden;
  background: #F5F5F5;
  color: #111A33;
}

.cart-header {
  display: none;
  height: 0;
  align-items: center;
  justify-content: center;
}

.cart-title {
  font-size: 36rpx;
  font-weight: 800;
}

.empty-card {
  width: 100%;
  max-width: 100%;
  height: 500rpx;
  box-sizing: border-box;
  padding: 36rpx 24rpx;
  border-radius: 24rpx;
  background: #ffffff;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.empty-illustration {
  position: relative;
  width: 320rpx;
  height: 240rpx;
  margin-top: 8rpx;
}

.cart-basket {
  position: absolute;
  left: 42rpx;
  top: 62rpx;
  width: 232rpx;
  height: 132rpx;
  border: 10rpx solid #DCEEFF;
  border-top: 0;
  border-radius: 0 0 34rpx 34rpx;
  background: linear-gradient(180deg, #ffffff, #eaf4ff);
}

.cart-basket::before {
  content: "";
  position: absolute;
  left: 44rpx;
  top: -58rpx;
  width: 120rpx;
  height: 72rpx;
  border: 10rpx solid #DCEEFF;
  border-bottom: 0;
  border-radius: 80rpx 80rpx 0 0;
}

.empty-chip {
  position: absolute;
  border-radius: 50%;
  background: #FF3D45;
}

.empty-chip.one {
  right: 46rpx;
  top: 44rpx;
  width: 42rpx;
  height: 42rpx;
}

.empty-chip.two {
  left: 52rpx;
  bottom: 32rpx;
  width: 32rpx;
  height: 32rpx;
  background: #D8A84A;
}

.empty-text {
  margin-top: 10rpx;
  font-size: 28rpx;
  color: #666666;
}

.primary-button {
  width: 288rpx;
  height: 80rpx;
  margin: 34rpx 0 0;
  padding: 0;
  border-radius: 40rpx;
  background: #FF3D45;
  color: #ffffff;
  font-size: 28rpx;
  line-height: 80rpx;
}

.primary-button::after,
.clear-button::after,
.mini-add::after,
.quantity-btn::after,
.checkout-button::after {
  border: 0;
}

.section-title {
  margin: 32rpx 0 18rpx;
  font-size: 30rpx;
  font-weight: 800;
}

.recommend-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 18rpx;
}

.recommend-card {
  max-width: 100%;
  min-height: 340rpx;
  box-sizing: border-box;
  padding: 16rpx;
  border-radius: 20rpx;
  background: #ffffff;
}

.recommend-image,
.cart-image {
  background:
    radial-gradient(circle at 72% 24%, rgba(255, 255, 255, 0.35), transparent 20%),
    linear-gradient(135deg, #08103e, #8c1d2a 58%, #D8A84A);
}

.recommend-image {
  height: 200rpx;
  border-radius: 16rpx;
}

.recommend-name {
  margin-top: 14rpx;
  font-size: 28rpx;
  font-weight: 700;
  color: #111A33;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.recommend-bottom {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-top: 12rpx;
}

.recommend-price {
  color: #FF3D45;
  font-size: 34rpx;
  font-weight: 800;
}

.mini-add {
  width: 40rpx;
  height: 40rpx;
  min-width: 40rpx;
  max-width: 40rpx;
  min-height: 40rpx;
  max-height: 40rpx;
  padding: 0;
  border-radius: 50%;
  background: #FF3D45;
  color: #ffffff;
  font-size: 28rpx;
  line-height: 40rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  box-sizing: border-box;
  flex-shrink: 0;
}

.table-card,
.remark-card,
.summary-card,
.cart-list {
  max-width: 100%;
  box-sizing: border-box;
  border-radius: 20rpx;
  background: #ffffff;
}

.table-card {
  height: 112rpx;
  box-sizing: border-box;
  padding: 0 28rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.table-label {
  font-size: 26rpx;
  color: #666666;
}

.table-no {
  color: #FF3D45;
  font-size: 38rpx;
  font-weight: 800;
}

.clear-button {
  width: 96rpx;
  height: 48rpx;
  min-width: 96rpx;
  max-width: 96rpx;
  min-height: 48rpx;
  max-height: 48rpx;
  margin: 0;
  padding: 0;
  border-radius: 24rpx;
  border: 2rpx solid #D8A84A;
  background: #ffffff;
  color: #8b5d12;
  font-size: 24rpx;
  line-height: 48rpx;
  box-sizing: border-box;
}

.cart-list {
  margin-top: 20rpx;
  padding: 8rpx 18rpx;
}

.cart-item {
  position: relative;
  min-height: 166rpx;
  box-sizing: border-box;
  padding: 18rpx 130rpx 18rpx 126rpx;
  border-bottom: 1rpx solid #eeeeee;
}

.cart-item:last-child {
  border-bottom: 0;
}

.cart-image {
  position: absolute;
  left: 0;
  top: 22rpx;
  width: 108rpx;
  height: 108rpx;
  border-radius: 16rpx;
}

.cart-name {
  font-size: 28rpx;
  font-weight: 800;
  color: #111A33;
}

.cart-desc {
  margin-top: 8rpx;
  font-size: 22rpx;
  color: #777777;
  line-height: 1.35;
  display: -webkit-box;
  overflow: hidden;
  text-overflow: ellipsis;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
}

.cart-price {
  margin-top: 10rpx;
  color: #FF3D45;
  font-size: 30rpx;
  font-weight: 800;
}

.cart-subtotal {
  margin-top: 4rpx;
  color: #999999;
  font-size: 22rpx;
}

.quantity-control {
  position: absolute;
  right: 0;
  bottom: 22rpx;
  width: 112rpx;
  height: 40rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  flex-shrink: 0;
}

.quantity-btn {
  width: 36rpx;
  height: 36rpx;
  min-width: 36rpx;
  max-width: 36rpx;
  min-height: 36rpx;
  max-height: 36rpx;
  padding: 0;
  border-radius: 50%;
  background: #FF3D45;
  color: #ffffff;
  font-size: 24rpx;
  line-height: 36rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  box-sizing: border-box;
}

.quantity-num {
  width: 32rpx;
  text-align: center;
  font-size: 24rpx;
  font-weight: 600;
  color: #111A33;
}

.remark-card {
  margin-top: 20rpx;
  height: 108rpx;
  box-sizing: border-box;
  padding: 16rpx 24rpx;
}

.remark-label {
  font-size: 24rpx;
  font-weight: 700;
}

.remark-input {
  margin-top: 10rpx;
  height: 42rpx;
  font-size: 24rpx;
}

.remark-placeholder {
  color: #999999;
}

.summary-card {
  margin-top: 20rpx;
  padding: 20rpx 24rpx;
}

.summary-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  font-size: 26rpx;
  color: #555555;
}

.summary-row.total {
  margin-top: 16rpx;
  color: #111A33;
  font-size: 30rpx;
  font-weight: 800;
}

.gold-text {
  color: #D8A84A;
  font-weight: 800;
}

.checkout-button {
  width: 100%;
  max-width: 694rpx;
  height: 84rpx;
  margin: 24rpx 0 0;
  padding: 0;
  border-radius: 44rpx;
  background: #FF3D45;
  color: #ffffff;
  font-size: 30rpx;
  font-weight: 800;
  line-height: 84rpx;
}
