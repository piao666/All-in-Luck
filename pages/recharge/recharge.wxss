.recharge-page {
  min-height: 100vh;
  box-sizing: border-box;
  padding: 30rpx 28rpx 56rpx;
  background:
    radial-gradient(circle at 82% 14%, rgba(216, 168, 74, 0.16), transparent 25%),
    linear-gradient(180deg, #070b34 0%, #13164F 48%, #07103a 100%);
  color: #ffffff;
}

.member-card {
  position: relative;
  min-height: 256rpx;
  box-sizing: border-box;
  padding: 30rpx;
  border: 2rpx solid rgba(216, 168, 74, 0.48);
  border-radius: 24rpx;
  overflow: hidden;
  background:
    radial-gradient(circle at 84% 30%, rgba(216, 168, 74, 0.28), transparent 24%),
    linear-gradient(135deg, #111111, #332b20 58%, #0a0f38);
}

.card-brand {
  width: 142rpx;
  height: 86rpx;
  box-sizing: border-box;
  padding: 16rpx;
  border: 2rpx solid #D8A84A;
  border-radius: 16rpx;
  color: #D8A84A;
  font-size: 22rpx;
  font-weight: 900;
}

.card-brand text {
  display: block;
  line-height: 1.15;
}

.card-copy {
  margin-top: 28rpx;
}

.page-title {
  font-size: 42rpx;
  font-weight: 900;
}

.page-subtitle {
  margin-top: 10rpx;
  color: rgba(255, 255, 255, 0.7);
  font-size: 24rpx;
}

.balance-row {
  display: flex;
  align-items: center;
  gap: 18rpx;
  margin-top: 20rpx;
  color: rgba(255, 255, 255, 0.82);
  font-size: 24rpx;
}

.balance-value {
  color: #ffe2a1;
  font-size: 34rpx;
  font-weight: 900;
}

.card-chip {
  position: absolute;
  right: 34rpx;
  top: 42rpx;
  width: 54rpx;
  height: 54rpx;
  border: 8rpx solid #D8A84A;
  border-radius: 50%;
  background: #13164F;
  box-sizing: border-box;
}

.section-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-top: 30rpx;
  font-size: 30rpx;
  font-weight: 900;
}

.section-tip {
  color: rgba(255, 255, 255, 0.6);
  font-size: 22rpx;
  font-weight: 400;
}

.plan-list {
  margin-top: 18rpx;
}

.plan-card {
  display: flex;
  align-items: center;
  justify-content: space-between;
  min-height: 132rpx;
  box-sizing: border-box;
  margin-bottom: 18rpx;
  padding: 22rpx 24rpx;
  border: 2rpx solid rgba(255, 255, 255, 0.1);
  border-radius: 20rpx;
  background: rgba(8, 14, 54, 0.8);
}

.plan-card.active {
  border-color: #D8A84A;
  background:
    radial-gradient(circle at 90% 34%, rgba(216, 168, 74, 0.2), transparent 22%),
    linear-gradient(135deg, #d81f2b, #9a141e);
}

.plan-main {
  flex: 1;
  min-width: 0;
}

.plan-amount {
  font-size: 34rpx;
  font-weight: 900;
}

.plan-desc {
  margin-top: 10rpx;
  color: rgba(255, 255, 255, 0.68);
  font-size: 23rpx;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.plan-gift {
  width: 150rpx;
  flex: 0 0 150rpx;
  text-align: right;
}

.gift-label {
  display: inline-block;
  width: 82rpx;
  height: 34rpx;
  border-radius: 17rpx;
  background: rgba(216, 168, 74, 0.24);
  color: #ffe2a1;
  font-size: 20rpx;
  line-height: 34rpx;
  text-align: center;
}

.gift-value {
  display: block;
  margin-top: 10rpx;
  color: #ffe2a1;
  font-size: 32rpx;
  font-weight: 900;
}

.summary-card,
.rule-card {
  border: 2rpx solid rgba(216, 168, 74, 0.24);
  border-radius: 20rpx;
  background: rgba(8, 14, 54, 0.78);
}

.summary-card {
  margin-top: 24rpx;
  padding: 24rpx;
}

.summary-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 18rpx;
  color: rgba(255, 255, 255, 0.78);
  font-size: 26rpx;
}

.gold-text {
  color: #D8A84A;
  font-size: 30rpx;
  font-weight: 900;
}

.recharge-button {
  width: 184rpx;
  height: 60rpx;
  margin: 22rpx 0 0 auto;
  padding: 0;
  border-radius: 30rpx;
  background: #FF3D45;
  color: #ffffff;
  font-size: 25rpx;
  font-weight: 800;
  line-height: 60rpx;
}

.recharge-button::after {
  border: 0;
}

.rule-card {
  margin-top: 22rpx;
  padding: 24rpx;
}

.rule-title {
  color: #D8A84A;
  font-size: 28rpx;
  font-weight: 800;
}

.rule-row {
  margin-top: 14rpx;
  color: rgba(255, 255, 255, 0.72);
  font-size: 24rpx;
  line-height: 1.45;
}
