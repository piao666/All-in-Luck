.mine-page {
  width: 100%;
  min-height: 100vh;
  box-sizing: border-box;
  padding-bottom: 132rpx;
  overflow-x: hidden;
  background: #F5F5F5;
  color: #111A33;
}

.member-hero {
  width: 100%;
  max-width: 100%;
  height: 320rpx;
  box-sizing: border-box;
  padding: 28rpx;
  background:
    radial-gradient(circle at 82% 28%, rgba(216, 168, 74, 0.18), transparent 26%),
    linear-gradient(180deg, #070b34, #13164F);
  color: #ffffff;
}

.hero-title {
  display: none;
  text-align: center;
  font-size: 36rpx;
  font-weight: 800;
}

.hero-content {
  position: relative;
  display: flex;
  align-items: center;
  margin-top: 18rpx;
}

.avatar {
  width: 96rpx;
  height: 96rpx;
  flex: 0 0 96rpx;
  border-radius: 50%;
  background:
    radial-gradient(circle at 50% 34%, #ffffff 0 16rpx, transparent 17rpx),
    radial-gradient(circle at 50% 76%, #ffffff 0 30rpx, transparent 31rpx),
    linear-gradient(135deg, #ffd8c4, #f1a27d);
}

.login-copy {
  flex: 1;
  min-width: 0;
  margin-left: 24rpx;
}

.login-title {
  font-size: 34rpx;
  font-weight: 800;
}

.login-subtitle {
  margin-top: 8rpx;
  color: rgba(255, 255, 255, 0.72);
  font-size: 24rpx;
}

.login-button {
  width: 200rpx;
  height: 66rpx;
  margin: 22rpx 0 0;
  padding: 0;
  border-radius: 36rpx;
  border: 2rpx solid rgba(216, 168, 74, 0.72);
  background: rgba(255, 255, 255, 0.08);
  color: #ffffff;
  font-size: 26rpx;
  line-height: 66rpx;
}

.login-button::after {
  border: 0;
}

.brand-card {
  width: 160rpx;
  height: 96rpx;
  box-sizing: border-box;
  padding: 18rpx 16rpx;
  border-radius: 16rpx;
  border: 2rpx solid rgba(216, 168, 74, 0.72);
  background: linear-gradient(135deg, #101010, #2b271e);
  color: #D8A84A;
  font-size: 22rpx;
  font-weight: 800;
}

.brand-card text {
  display: block;
}

.stats-card {
  display: grid;
  grid-template-columns: repeat(4, minmax(0, 1fr));
  max-width: 100%;
  height: 136rpx;
  margin: -44rpx 28rpx 0;
  border-radius: 20rpx;
  background: linear-gradient(180deg, #d81f2b, #a81521);
  color: #ffffff;
  overflow: hidden;
}

.stat-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  border-right: 1rpx solid rgba(255, 255, 255, 0.22);
}

.stat-item:last-child {
  border-right: 0;
}

.stat-value {
  font-size: 36rpx;
  font-weight: 800;
}

.stat-label {
  margin-top: 8rpx;
  font-size: 24rpx;
}

.white-card {
  max-width: 100%;
  box-sizing: border-box;
  margin: 24rpx 28rpx 0;
  border-radius: 20rpx;
  background: #ffffff;
}

.order-card {
  padding: 30rpx;
}

.card-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  font-size: 30rpx;
  font-weight: 800;
}

.card-more {
  color: #777777;
  font-size: 24rpx;
  font-weight: 400;
}

.order-status-row {
  display: grid;
  grid-template-columns: repeat(5, minmax(0, 1fr));
  margin-top: 30rpx;
}

.order-status,
.grid-item {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.icon-box {
  width: 48rpx;
  height: 48rpx;
  border: 4rpx solid #111A33;
  border-radius: 14rpx;
  box-sizing: border-box;
  color: #FF3D45;
  font-size: 24rpx;
  font-weight: 800;
  line-height: 40rpx;
  text-align: center;
}

.status-label {
  margin-top: 16rpx;
  font-size: 24rpx;
}

.grid-card {
  padding: 22rpx 18rpx;
}

.grid-list {
  display: grid;
  grid-template-columns: repeat(4, minmax(0, 1fr));
}

.grid-item {
  height: 128rpx;
  justify-content: center;
}

.grid-icon {
  color: #111A33;
  border-color: #D8A84A;
}

.grid-label {
  margin-top: 14rpx;
  font-size: 24rpx;
  text-align: center;
}

.points-banner {
  max-width: 100%;
  height: 144rpx;
  box-sizing: border-box;
  margin: 24rpx 28rpx 0;
  padding: 0 28rpx;
  border-radius: 18rpx;
  border: 2rpx solid rgba(216, 168, 74, 0.48);
  background: linear-gradient(135deg, #11194f, #07103a);
  color: #ffffff;
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.points-title {
  font-size: 32rpx;
  font-weight: 800;
}

.points-subtitle {
  margin-top: 10rpx;
  color: #D8A84A;
  font-size: 24rpx;
}

.points-arrow {
  width: 44rpx;
  height: 44rpx;
  border-radius: 50%;
  border: 2rpx solid rgba(255, 255, 255, 0.35);
  text-align: center;
  line-height: 44rpx;
}
