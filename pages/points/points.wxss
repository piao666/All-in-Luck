.points-page {
  min-height: 100vh;
  box-sizing: border-box;
  padding: 28rpx 28rpx 56rpx;
  background:
    radial-gradient(circle at 86% 10%, rgba(216, 168, 74, 0.14), transparent 24%),
    radial-gradient(circle at 14% 38%, rgba(255, 61, 69, 0.1), transparent 22%),
    linear-gradient(180deg, #070b34 0%, #13164F 48%, #07103a 100%);
  color: #ffffff;
}

.points-hero {
  padding-top: 10rpx;
}

.hero-top {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.hero-title {
  font-size: 42rpx;
  font-weight: 900;
}

.hero-subtitle {
  margin-top: 10rpx;
  color: rgba(255, 255, 255, 0.68);
  font-size: 24rpx;
}

.coin-icon {
  width: 56rpx;
  height: 56rpx;
  flex: 0 0 56rpx;
  border-radius: 50%;
  border: 4rpx solid #D8A84A;
  color: #D8A84A;
  font-size: 24rpx;
  font-weight: 900;
  line-height: 56rpx;
  text-align: center;
  box-sizing: border-box;
}

.points-card {
  height: 188rpx;
  box-sizing: border-box;
  margin-top: 26rpx;
  padding: 28rpx;
  border: 2rpx solid rgba(216, 168, 74, 0.42);
  border-radius: 22rpx;
  background:
    radial-gradient(circle at 86% 30%, rgba(216, 168, 74, 0.22), transparent 24%),
    linear-gradient(135deg, #d81f2b, #96131d);
}

.points-label,
.points-note {
  display: block;
  color: rgba(255, 255, 255, 0.8);
  font-size: 24rpx;
}

.points-value {
  display: block;
  margin-top: 10rpx;
  color: #ffe2a1;
  font-size: 56rpx;
  font-weight: 900;
  line-height: 1;
}

.points-note {
  margin-top: 14rpx;
}

.tab-scroll {
  width: 100%;
  margin-top: 24rpx;
  white-space: nowrap;
}

.tab-row {
  display: flex;
  gap: 14rpx;
}

.tab-item {
  width: 112rpx;
  height: 56rpx;
  flex: 0 0 112rpx;
  border: 2rpx solid rgba(255, 255, 255, 0.16);
  border-radius: 28rpx;
  color: rgba(255, 255, 255, 0.82);
  font-size: 24rpx;
  line-height: 56rpx;
  text-align: center;
  box-sizing: border-box;
}

.tab-item.active {
  border-color: #D8A84A;
  background: #FF3D45;
  color: #ffffff;
  font-weight: 800;
}

.gift-list {
  margin-top: 22rpx;
}

.gift-card {
  display: flex;
  min-height: 172rpx;
  box-sizing: border-box;
  margin-bottom: 18rpx;
  padding: 16rpx;
  border-radius: 20rpx;
  background: #DCEEFF;
  color: #111A33;
}

.gift-image {
  position: relative;
  width: 132rpx;
  height: 132rpx;
  flex: 0 0 132rpx;
  border-radius: 16rpx;
  overflow: hidden;
  background:
    radial-gradient(circle at 74% 22%, rgba(255, 255, 255, 0.32), transparent 20%),
    linear-gradient(135deg, #08103e, #8c1d2a 58%, #D8A84A);
}

.gift-image.beer,
.gift-image.craft-beer {
  background:
    radial-gradient(circle at 70% 20%, rgba(255, 255, 255, 0.4), transparent 20%),
    linear-gradient(135deg, #07123e, #9c6a16 55%, #f3c75a);
}

.gift-image.snack-plate {
  background:
    radial-gradient(circle at 62% 28%, rgba(255, 255, 255, 0.28), transparent 22%),
    linear-gradient(135deg, #14183d, #8c4718 58%, #D8A84A);
}

.image-chip {
  position: absolute;
  right: 14rpx;
  bottom: 14rpx;
  width: 34rpx;
  height: 34rpx;
  border: 5rpx solid #ffffff;
  border-radius: 50%;
  background: #FF3D45;
  box-sizing: border-box;
}

.image-glass {
  position: absolute;
  left: 42rpx;
  bottom: 22rpx;
  width: 34rpx;
  height: 62rpx;
  border: 5rpx solid rgba(255, 255, 255, 0.82);
  border-top-width: 8rpx;
  border-radius: 10rpx 10rpx 22rpx 22rpx;
}

.gift-info {
  flex: 1;
  min-width: 0;
  margin-left: 18rpx;
}

.gift-title-row {
  display: flex;
  align-items: center;
  gap: 10rpx;
}

.gift-name {
  flex: 1;
  min-width: 0;
  font-size: 28rpx;
  font-weight: 900;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.gift-tag {
  width: 76rpx;
  height: 34rpx;
  border-radius: 17rpx;
  background: rgba(216, 168, 74, 0.22);
  color: #8b5d12;
  font-size: 20rpx;
  line-height: 34rpx;
  text-align: center;
}

.gift-desc {
  margin-top: 10rpx;
  color: #526079;
  font-size: 23rpx;
  line-height: 1.35;
}

.gift-bottom {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-top: 18rpx;
}

.gift-points {
  color: #FF3D45;
  font-size: 30rpx;
  font-weight: 900;
}

.redeem-button {
  width: 132rpx;
  height: 54rpx;
  margin: 0;
  padding: 0;
  border-radius: 27rpx;
  background: #FF3D45;
  color: #ffffff;
  font-size: 23rpx;
  font-weight: 800;
  line-height: 54rpx;
}

.redeem-button::after {
  border: 0;
}

.rule-card {
  margin-top: 24rpx;
  padding: 24rpx;
  border: 2rpx solid rgba(216, 168, 74, 0.28);
  border-radius: 20rpx;
  background: rgba(8, 14, 54, 0.78);
}

.rule-title {
  color: #D8A84A;
  font-size: 28rpx;
  font-weight: 800;
}

.rule-row {
  margin-top: 14rpx;
  color: rgba(255, 255, 255, 0.74);
  font-size: 24rpx;
  line-height: 1.45;
}
