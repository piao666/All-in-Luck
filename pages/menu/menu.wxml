<view class="menu-page">
  <view class="top-bar">
    <view class="home-mark" bindtap="goHome"></view>
    <view class="title-wrap">
      <text class="gold-suit">♠</text>
      <text class="page-name">点单</text>
      <text class="gold-suit">◆</text>
    </view>
    <view class="top-actions">
      <text class="dot-more">•••</text>
      <text class="target-icon"></text>
    </view>
  </view>

  <view class="notice-card">
    <view class="speaker">
      <view></view>
    </view>
    <text class="notice-text">All in Luck 很高兴为您服务</text>
    <view class="notice-deco">
      <view class="deco-card">A</view>
      <view class="deco-chip"></view>
      <view class="deco-bottle"></view>
    </view>
  </view>

  <view class="menu-layout">
    <scroll-view class="category-panel" scroll-y="true" enhanced="true" show-scrollbar="false">
      <view
        wx:for="{{categories}}"
        wx:key="id"
        class="category-item {{selectedCategoryId === item.id ? 'active' : ''}}"
        data-id="{{item.id}}"
        bindtap="selectCategory"
      >
        <text>{{item.name}}</text>
      </view>
      <view class="category-brand">
        <text>ALL IN</text>
        <text>LUCK</text>
      </view>
    </scroll-view>

    <scroll-view class="product-panel" scroll-y="true" enhanced="true" show-scrollbar="false">
      <view wx:if="{{filteredProducts.length}}" class="product-list">
        <view
          wx:for="{{filteredProducts}}"
          wx:key="id"
          class="product-card"
          data-id="{{item.id}}"
          bindtap="goProductDetail"
        >
          <view class="product-image {{item.imageType}}">
            <view class="image-badge">ALL IN</view>
            <view class="drink-shapes">
              <view class="glass one"></view>
              <view class="glass two"></view>
              <view class="chip-mini"></view>
            </view>
          </view>
          <view class="product-info">
            <view class="product-title-row">
              <text class="product-name">{{item.name}}</text>
              <text class="product-tag">{{item.tag}}</text>
            </view>
            <view class="product-points">赠送 {{item.points}} 娱乐积分，{{item.desc}}</view>
            <view class="product-bottom">
              <view class="price">
                <text class="currency">￥</text>{{item.price}}
              </view>
              <view class="product-action">
                <view wx:if="{{cartMap[item.id]}}" class="quantity-control" catchtap="stopTap">
                  <button class="quantity-btn minus" data-id="{{item.id}}" catchtap="decreaseProduct">-</button>
                  <text class="quantity-num">{{cartMap[item.id]}}</text>
                  <button class="quantity-btn plus" data-id="{{item.id}}" catchtap="increaseProduct">+</button>
                </view>
                <button
                  wx:else
                  class="add-button"
                  data-id="{{item.id}}"
                  catchtap="increaseProduct"
                >+</button>
              </view>
            </view>
          </view>
        </view>
      </view>

      <view wx:else class="empty-panel">
        <view class="empty-icon">♠</view>
        <view class="empty-title">当前分类暂无商品</view>
        <view class="empty-text">请先查看其他酒水或套餐</view>
      </view>
    </scroll-view>
  </view>

  <view wx:if="{{totalCount > 0}}" class="cart-bar" catchtap="openCartPanel">
    <view class="cart-bar-left">
      <view class="cart-bag">
        <text>{{totalCount}}</text>
      </view>
      <view class="cart-bar-copy">
        <view class="cart-bar-title">本地购物车</view>
        <view class="cart-bar-amount">￥{{totalAmount}}</view>
      </view>
    </view>
    <button class="cart-checkout-btn" catchtap="goCart">去购物车结算</button>
  </view>

  <view wx:if="{{isCartPanelVisible}}" class="cart-panel-mask" catchtap="closeCartPanel"></view>
  <view wx:if="{{isCartPanelVisible}}" class="cart-panel" catchtap="stopTap">
    <view class="cart-panel-head">
      <button class="cart-clear-btn" catchtap="clearCart">清空</button>
      <button class="cart-close-btn" catchtap="closeCartPanel">⌄</button>
    </view>
    <scroll-view class="cart-panel-list" scroll-y="true" enhanced="true" show-scrollbar="false">
      <view wx:for="{{cartItems}}" wx:key="id" class="cart-panel-item">
        <view class="panel-item-image {{item.imageType}}"></view>
        <view class="panel-item-info">
          <view class="panel-item-name">{{item.name}}</view>
          <view class="panel-item-desc">{{item.desc}}</view>
          <view class="panel-item-price">￥{{item.price}}</view>
        </view>
        <view class="quantity-control panel-quantity" catchtap="stopTap">
          <button class="quantity-btn minus" data-id="{{item.id}}" catchtap="decreaseCartItem">-</button>
          <text class="quantity-num">{{item.count}}</text>
          <button class="quantity-btn plus" data-id="{{item.id}}" catchtap="increaseCartItem">+</button>
        </view>
      </view>
    </scroll-view>
    <view class="cart-panel-foot">
      <view>
        <view class="panel-foot-count">共 {{totalCount}} 件</view>
        <view class="panel-foot-amount">￥{{totalAmount}}</view>
      </view>
      <button class="panel-checkout-btn" catchtap="goCart">去购物车结算</button>
    </view>
  </view>
</view>
