.menu-page {
  position: relative;
  width: 100%;
  min-height: 100vh;
  box-sizing: border-box;
  padding: 28rpx 24rpx 28rpx;
  overflow-x: hidden;
  background:
    radial-gradient(circle at 84% 12%, rgba(216, 168, 74, 0.13), transparent 24%),
    radial-gradient(circle at 18% 34%, rgba(255, 61, 69, 0.1), transparent 22%),
    linear-gradient(180deg, #070b34 0%, #13164F 48%, #07103a 100%);
}

.menu-page::before {
  content: "";
  position: absolute;
  inset: 0;
  opacity: 0.22;
  background-image:
    radial-gradient(circle, rgba(216, 168, 74, 0.22) 0 2rpx, transparent 3rpx),
    linear-gradient(135deg, transparent 0 48%, rgba(255, 255, 255, 0.05) 49% 51%, transparent 52%);
  background-size: 150rpx 150rpx, 190rpx 190rpx;
  pointer-events: none;
}

.top-bar,
.notice-card,
.menu-layout {
  position: relative;
  z-index: 1;
}

.top-bar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 4rpx 8rpx 22rpx;
}

.home-mark {
  width: 56rpx;
  height: 56rpx;
  flex: 0 0 56rpx;
}

.home-mark {
  position: relative;
}

.home-mark::before {
  content: "";
  position: absolute;
  left: 9rpx;
  top: 18rpx;
  width: 34rpx;
  height: 34rpx;
  border: 5rpx solid #ffffff;
  border-top: 0;
  border-radius: 4rpx;
}

.home-mark::after {
  content: "";
  position: absolute;
  left: 11rpx;
  top: 5rpx;
  width: 34rpx;
  height: 34rpx;
  border-left: 5rpx solid #ffffff;
  border-top: 5rpx solid #ffffff;
  transform: rotate(45deg);
}

.title-wrap {
  display: none;
  align-items: center;
  gap: 28rpx;
}

.gold-suit {
  color: #D8A84A;
  font-size: 28rpx;
}

.page-name {
  color: #ffffff;
  font-size: 44rpx;
  font-weight: 900;
  letter-spacing: 0;
}

.top-actions {
  display: flex;
  align-items: center;
  justify-content: space-around;
  width: 116rpx;
  height: 54rpx;
  flex: 0 0 116rpx;
  border: 2rpx solid rgba(255, 255, 255, 0.22);
  border-radius: 999rpx;
  background: rgba(3, 8, 38, 0.34);
}

.dot-more {
  color: #ffffff;
  font-size: 26rpx;
  letter-spacing: 2rpx;
}

.target-icon {
  width: 28rpx;
  height: 28rpx;
  border: 6rpx solid #ffffff;
  border-radius: 50%;
  box-sizing: border-box;
  box-shadow: 0 0 0 4rpx rgba(255, 255, 255, 0.24);
}

.notice-card {
  display: flex;
  align-items: center;
  min-height: 74rpx;
  box-sizing: border-box;
  padding: 12rpx 20rpx;
  border: 2rpx solid rgba(216, 168, 74, 0.42);
  border-radius: 16rpx;
  overflow: hidden;
  background:
    radial-gradient(circle at 88% 50%, rgba(216, 168, 74, 0.16), transparent 28%),
    linear-gradient(100deg, rgba(12, 18, 64, 0.98), rgba(18, 28, 84, 0.86));
}

.speaker {
  position: relative;
  width: 46rpx;
  height: 46rpx;
  flex: 0 0 46rpx;
  margin-right: 18rpx;
}

.speaker::before {
  content: "";
  position: absolute;
  left: 4rpx;
  top: 18rpx;
  width: 14rpx;
  height: 18rpx;
  border-radius: 4rpx;
  background: #FF3D45;
}

.speaker::after {
  content: "";
  position: absolute;
  left: 20rpx;
  top: 10rpx;
  width: 0;
  height: 0;
  border-top: 18rpx solid transparent;
  border-bottom: 18rpx solid transparent;
  border-left: 24rpx solid #FF3D45;
}

.speaker view {
  position: absolute;
  right: -2rpx;
  top: 11rpx;
  width: 24rpx;
  height: 30rpx;
  border: 5rpx solid #FF3D45;
  border-left: 0;
  border-radius: 0 50% 50% 0;
}

.notice-text {
  flex: 1;
  min-width: 0;
  color: #f6d58a;
  font-size: 26rpx;
  font-weight: 600;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.notice-deco {
  position: relative;
  width: 180rpx;
  height: 54rpx;
  flex: 0 0 180rpx;
  opacity: 0.45;
}

.deco-card {
  position: absolute;
  left: 22rpx;
  top: 8rpx;
  width: 42rpx;
  height: 56rpx;
  border-radius: 6rpx;
  background: #ffffff;
  color: #111947;
  font-size: 18rpx;
  font-weight: 800;
  text-align: center;
  line-height: 34rpx;
  transform: rotate(-12deg);
}

.deco-chip {
  position: absolute;
  left: 72rpx;
  top: 22rpx;
  width: 44rpx;
  height: 44rpx;
  border: 7rpx solid #D8A84A;
  border-radius: 50%;
  background: #13164F;
}

.deco-bottle {
  position: absolute;
  right: 16rpx;
  bottom: 4rpx;
  width: 28rpx;
  height: 58rpx;
  border-radius: 10rpx 10rpx 6rpx 6rpx;
  background: linear-gradient(90deg, #29120a, #D8A84A, #2b1209);
}

.menu-layout {
  display: flex;
  gap: 14rpx;
  height: calc(100vh - 160rpx);
  min-height: 820rpx;
  margin-top: 18rpx;
  padding-bottom: 142rpx;
  box-sizing: border-box;
}

.category-panel {
  width: 164rpx;
  height: 100%;
  flex: 0 0 164rpx;
  box-sizing: border-box;
  border: 2rpx solid rgba(216, 168, 74, 0.15);
  border-radius: 20rpx;
  overflow: hidden;
  background: linear-gradient(180deg, #091044, #081039);
}

.category-item {
  position: relative;
  display: flex;
  align-items: center;
  justify-content: center;
  min-height: 104rpx;
  box-sizing: border-box;
  padding: 0 12rpx;
  color: rgba(255, 255, 255, 0.84);
  font-size: 25rpx;
  line-height: 1.25;
  text-align: center;
  border-bottom: 1rpx solid rgba(255, 255, 255, 0.08);
}

.category-item.active {
  color: #ffffff;
  font-weight: 800;
  background: linear-gradient(180deg, #FF3D45, #b91421);
}

.category-item.active::after {
  content: "";
  position: absolute;
  left: 50%;
  bottom: -10rpx;
  width: 18rpx;
  height: 18rpx;
  border-left: 3rpx solid #D8A84A;
  border-bottom: 3rpx solid #D8A84A;
  transform: translateX(-50%) rotate(-45deg);
}

.category-brand {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  height: 170rpx;
  color: #D8A84A;
  font-size: 22rpx;
  font-weight: 900;
  opacity: 0.74;
}

.product-panel {
  height: 100%;
  flex: 1;
  min-width: 0;
}

.product-list {
  padding-bottom: 220rpx;
}

.product-card {
  position: relative;
  display: flex;
  gap: 20rpx;
  width: 100%;
  max-width: 100%;
  height: 198rpx;
  min-height: 198rpx;
  max-height: 198rpx;
  box-sizing: border-box;
  margin-bottom: 20rpx;
  padding: 14rpx;
  overflow: hidden;
  border-radius: 18rpx;
  background: #DCEEFF;
  box-shadow: 0 14rpx 28rpx rgba(0, 0, 0, 0.22);
}

.product-image {
  position: relative;
  width: 138rpx;
  height: 120rpx;
  flex: 0 0 138rpx;
  border-radius: 12rpx;
  overflow: hidden;
  background:
    radial-gradient(circle at 72% 22%, rgba(255, 255, 255, 0.32), transparent 18%),
    linear-gradient(135deg, #0a0f35, #7a1a24 58%, #D8A84A);
}

.product-image.beer,
.product-image.beer-light,
.product-image.craft-beer {
  background:
    radial-gradient(circle at 70% 20%, rgba(255, 255, 255, 0.4), transparent 20%),
    linear-gradient(135deg, #07123e, #9c6a16 55%, #f3c75a);
}

.product-image.cocktail,
.product-image.mojito,
.product-image.long-island {
  background:
    radial-gradient(circle at 25% 28%, rgba(71, 201, 255, 0.42), transparent 22%),
    linear-gradient(135deg, #070c32, #c82459 56%, #29a7d7);
}

.product-image.cola,
.product-image.soda,
.product-image.sparkling {
  background:
    radial-gradient(circle at 68% 28%, rgba(255, 255, 255, 0.36), transparent 22%),
    linear-gradient(135deg, #07123e, #1b4e92 58%, #b91e28);
}

.product-image.snack-plate,
.product-image.fries,
.product-image.nuts {
  background:
    radial-gradient(circle at 62% 28%, rgba(255, 255, 255, 0.28), transparent 22%),
    linear-gradient(135deg, #14183d, #8c4718 58%, #D8A84A);
}

.image-badge {
  position: absolute;
  left: 8rpx;
  top: 8rpx;
  z-index: 2;
  padding: 3rpx 5rpx;
  border-radius: 6rpx;
  background: rgba(19, 22, 79, 0.84);
  color: #ffffff;
  font-size: 11rpx;
  font-weight: 900;
}

.drink-shapes {
  position: absolute;
  inset: 0;
}

.glass {
  position: absolute;
  bottom: 15rpx;
  width: 22rpx;
  height: 40rpx;
  border: 3rpx solid rgba(255, 255, 255, 0.82);
  border-top-width: 5rpx;
  border-radius: 8rpx 8rpx 18rpx 18rpx;
}

.glass.one {
  left: 32rpx;
  transform: rotate(-8deg);
}

.glass.two {
  left: 58rpx;
  height: 48rpx;
  border-color: rgba(216, 168, 74, 0.88);
  transform: rotate(7deg);
}

.chip-mini {
  position: absolute;
  right: 12rpx;
  bottom: 10rpx;
  width: 26rpx;
  height: 26rpx;
  border: 4rpx solid #ffffff;
  border-radius: 50%;
  background: #FF3D45;
}

.product-info {
  flex: 1;
  min-width: 0;
  padding-right: 0;
}

.product-title-row {
  display: flex;
  align-items: flex-start;
  gap: 8rpx;
}

.product-name {
  flex: 1;
  min-width: 0;
  color: #101836;
  font-size: 31rpx;
  font-weight: 900;
  line-height: 1.2;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.product-tag {
  max-width: 92rpx;
  padding: 3rpx 7rpx;
  border-radius: 999rpx;
  background: rgba(216, 168, 74, 0.22);
  color: #8b5d12;
  font-size: 19rpx;
  line-height: 1.2;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.product-points {
  color: #1f2a4b;
  font-size: 23rpx;
  line-height: 1.32;
  display: -webkit-box;
  overflow: hidden;
  text-overflow: ellipsis;
  -webkit-box-orient: vertical;
}

.product-points {
  margin-top: 9rpx;
  -webkit-line-clamp: 2;
}

.product-bottom {
  position: absolute;
  left: 172rpx;
  right: 16rpx;
  bottom: 10rpx;
  display: flex;
  align-items: center;
  justify-content: flex-start;
  height: 40rpx;
}

.price {
  color: #d71927;
  font-size: 36rpx;
  font-weight: 900;
  line-height: 1;
}

.currency {
  margin-right: 3rpx;
  font-size: 22rpx;
}

.product-action {
  position: absolute;
  right: 0;
  bottom: 0;
  display: flex;
  align-items: center;
  justify-content: center;
}

.add-button {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 40rpx;
  height: 40rpx;
  min-width: 40rpx;
  max-width: 40rpx;
  min-height: 40rpx;
  max-height: 40rpx;
  margin: 0;
  padding: 0;
  border-radius: 50%;
  background: #FF3D45;
  color: #ffffff;
  font-size: 28rpx;
  font-weight: 500;
  line-height: 40rpx;
  text-align: center;
  box-sizing: border-box;
  flex-shrink: 0;
  box-shadow: 0 8rpx 18rpx rgba(255, 61, 69, 0.32);
}

.add-button::after {
  border: 0;
}

.quantity-control {
  display: flex;
  align-items: center;
  justify-content: space-between;
  width: 112rpx;
  height: 40rpx;
  flex-shrink: 0;
}

.quantity-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 36rpx;
  height: 36rpx;
  min-width: 36rpx;
  max-width: 36rpx;
  min-height: 36rpx;
  max-height: 36rpx;
  margin: 0;
  padding: 0;
  border-radius: 50%;
  background: #FF3D45;
  color: #ffffff;
  font-size: 24rpx;
  line-height: 36rpx;
  box-sizing: border-box;
}

.quantity-btn::after {
  border: 0;
}

.quantity-num {
  width: 32rpx;
  color: #111A33;
  font-size: 24rpx;
  font-weight: 600;
  text-align: center;
}

.cart-bar {
  position: fixed;
  left: 28rpx;
  right: 28rpx;
  bottom: 84rpx;
  z-index: 30;
  display: flex;
  align-items: center;
  justify-content: space-between;
  height: 96rpx;
  box-sizing: border-box;
  padding: 0 8rpx 0 28rpx;
  border-radius: 52rpx;
  background: rgba(0, 0, 0, 0.88);
  box-shadow: 0 18rpx 34rpx rgba(0, 0, 0, 0.28);
}

.cart-bar-left {
  display: flex;
  align-items: center;
  min-width: 0;
  flex-shrink: 1;
  margin-right: 16rpx;
}

.cart-bag {
  position: relative;
  width: 58rpx;
  height: 58rpx;
  flex: 0 0 58rpx;
  border-radius: 18rpx;
  background: #FF3D45;
  color: #ffffff;
  font-size: 22rpx;
  font-weight: 900;
  line-height: 58rpx;
  text-align: center;
}

.cart-bag::before {
  content: "";
  position: absolute;
  left: 15rpx;
  top: -9rpx;
  width: 24rpx;
  height: 18rpx;
  border: 4rpx solid #FF3D45;
  border-bottom: 0;
  border-radius: 18rpx 18rpx 0 0;
}

.cart-bar-copy {
  min-width: 0;
  margin-left: 16rpx;
}

.cart-bar-title {
  color: rgba(255, 255, 255, 0.76);
  font-size: 22rpx;
  line-height: 1.2;
}

.cart-bar-amount {
  margin-top: 4rpx;
  color: #D8A84A;
  font-size: 30rpx;
  font-weight: 900;
  line-height: 1;
}

.cart-checkout-btn,
.panel-checkout-btn {
  width: 220rpx;
  height: 64rpx;
  flex: 0 0 220rpx;
  margin: 0;
  padding: 0;
  border-radius: 32rpx;
  background: #FF3D45;
  color: #ffffff;
  font-size: 25rpx;
  font-weight: 800;
  line-height: 64rpx;
  box-sizing: border-box;
}

.cart-checkout-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 260rpx;
  height: 68rpx;
  flex: 0 0 260rpx;
  margin-left: auto;
  margin-right: 0;
  border-radius: 36rpx;
  font-size: 28rpx;
  font-weight: 600;
  line-height: 68rpx;
  text-indent: 0;
}

.cart-checkout-btn::after,
.cart-clear-btn::after,
.cart-close-btn::after,
.panel-checkout-btn::after {
  border: 0;
}

.cart-panel-mask {
  position: fixed;
  left: 0;
  right: 0;
  top: 0;
  bottom: 0;
  z-index: 29;
  background: rgba(0, 0, 0, 0.42);
}

.cart-panel {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 30;
  height: 620rpx;
  max-height: 680rpx;
  box-sizing: border-box;
  padding: 24rpx 28rpx 132rpx;
  border-radius: 28rpx 28rpx 0 0;
  background: #ffffff;
  color: #111A33;
  overflow: hidden;
}

.cart-panel-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  height: 64rpx;
}

.cart-clear-btn {
  width: 96rpx;
  height: 48rpx;
  margin: 0;
  padding: 0;
  border-radius: 24rpx;
  border: 2rpx solid #D8A84A;
  background: #ffffff;
  color: #8b5d12;
  font-size: 24rpx;
  line-height: 48rpx;
}

.cart-close-btn {
  width: 48rpx;
  height: 48rpx;
  margin: 0;
  padding: 0;
  border-radius: 50%;
  background: rgba(17, 26, 51, 0.08);
  color: #111A33;
  font-size: 34rpx;
  line-height: 44rpx;
}

.cart-panel-list {
  height: 390rpx;
  margin-top: 12rpx;
}

.cart-panel-item {
  position: relative;
  min-height: 136rpx;
  box-sizing: border-box;
  padding: 18rpx 132rpx 18rpx 112rpx;
  border-bottom: 1rpx solid #eeeeee;
}

.cart-panel-item:last-child {
  border-bottom: 0;
}

.panel-item-image {
  position: absolute;
  left: 0;
  top: 18rpx;
  width: 92rpx;
  height: 92rpx;
  border-radius: 14rpx;
  background:
    radial-gradient(circle at 72% 24%, rgba(255, 255, 255, 0.35), transparent 20%),
    linear-gradient(135deg, #08103e, #8c1d2a 58%, #D8A84A);
}

.panel-item-info {
  min-width: 0;
}

.panel-item-name {
  color: #111A33;
  font-size: 28rpx;
  font-weight: 900;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.panel-item-desc {
  margin-top: 8rpx;
  color: #777777;
  font-size: 22rpx;
  line-height: 1.35;
  display: -webkit-box;
  overflow: hidden;
  text-overflow: ellipsis;
  -webkit-line-clamp: 1;
  -webkit-box-orient: vertical;
}

.panel-item-price {
  margin-top: 10rpx;
  color: #FF3D45;
  font-size: 28rpx;
  font-weight: 900;
}

.panel-quantity {
  position: absolute;
  right: 0;
  bottom: 28rpx;
}

.cart-panel-foot {
  position: absolute;
  left: 28rpx;
  right: 28rpx;
  bottom: 30rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  height: 86rpx;
  box-sizing: border-box;
  padding-top: 16rpx;
  border-top: 1rpx solid #eeeeee;
}

.panel-foot-count {
  color: #777777;
  font-size: 22rpx;
}

.panel-foot-amount {
  margin-top: 4rpx;
  color: #FF3D45;
  font-size: 34rpx;
  font-weight: 900;
  line-height: 1;
}

.empty-panel {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  min-height: 520rpx;
  box-sizing: border-box;
  padding: 48rpx 24rpx;
  border: 2rpx solid rgba(216, 168, 74, 0.24);
  border-radius: 22rpx;
  background: rgba(8, 14, 54, 0.72);
  text-align: center;
}

.empty-icon {
  color: #D8A84A;
  font-size: 76rpx;
}

.empty-title {
  margin-top: 20rpx;
  color: #ffffff;
  font-size: 30rpx;
  font-weight: 800;
}

.empty-text {
  margin-top: 10rpx;
  color: rgba(255, 255, 255, 0.68);
  font-size: 24rpx;
}
