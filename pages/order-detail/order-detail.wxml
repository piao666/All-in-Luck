<view class="detail-page">
  <view class="status-hero">
    <view>
      <view class="status-label">订单状态</view>
      <view class="status-title">{{order.status}}</view>
      <view class="status-desc">订单号 {{order.id}}</view>
    </view>
    <view class="status-icon {{order.statusType}}">单</view>
  </view>

  <view class="verify-card">
    <view class="verify-head">
      <text>到店使用凭证</text>
      <text class="table-no">桌号 {{order.tableNo}}</text>
    </view>
    <view class="verify-code">{{order.verifyCode}}</view>
    <view class="verify-tip">请向服务员出示此页面，当前仅为 UI 演示。</view>
  </view>

  <view class="white-card">
    <view class="card-title">商品明细</view>
    <view wx:for="{{order.items}}" wx:key="name" class="item-row">
      <view class="item-image {{item.imageType}}"></view>
      <view class="item-info">
        <view class="item-name">{{item.name}}</view>
        <view class="item-desc">{{item.desc}}</view>
        <view class="item-price">¥{{item.price}}</view>
      </view>
      <view class="item-count">x{{item.count}}</view>
    </view>
  </view>

  <view class="white-card amount-card">
    <view class="amount-row">
      <text>支付方式</text>
      <text>{{order.payment}}</text>
    </view>
    <view class="amount-row">
      <text>赠送积分</text>
      <text class="gold-text">{{order.points}}</text>
    </view>
    <view class="amount-row total">
      <text>订单金额</text>
      <text>¥{{order.totalAmount}}</text>
    </view>
  </view>

  <view class="white-card">
    <view class="card-title">订单进度</view>
    <view wx:for="{{timeline}}" wx:key="label" class="timeline-row">
      <view class="timeline-dot {{item.active ? 'active' : ''}}"></view>
      <view class="timeline-copy">
        <view class="timeline-label">{{item.label}}</view>
        <view class="timeline-value">{{item.value}}</view>
      </view>
    </view>
  </view>

  <view class="white-card info-card">
    <view class="info-row">
      <text>备注</text>
      <text>{{order.remark}}</text>
    </view>
    <view class="info-row">
      <text>使用说明</text>
      <text>到店后由服务员核对订单信息</text>
    </view>
  </view>

  <button
    wx:if="{{order.statusType !== 'done'}}"
    class="primary-button"
    bindtap="handlePrimaryAction"
  >{{order.statusType === 'pending' ? '去付款' : '出示使用'}}</button>
</view>
