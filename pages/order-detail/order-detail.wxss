.detail-page {
  min-height: 100vh;
  box-sizing: border-box;
  padding: 0 28rpx 56rpx;
  background: #F5F5F5;
  color: #111A33;
}

.status-hero {
  min-height: 244rpx;
  margin: 0 -28rpx;
  padding: 44rpx 28rpx 38rpx;
  box-sizing: border-box;
  background:
    radial-gradient(circle at 86% 16%, rgba(216, 168, 74, 0.18), transparent 24%),
    linear-gradient(180deg, #070b34, #13164F);
  color: #ffffff;
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
}

.status-label {
  color: rgba(255, 255, 255, 0.68);
  font-size: 24rpx;
}

.status-title {
  margin-top: 12rpx;
  color: #ffe2a1;
  font-size: 46rpx;
  font-weight: 900;
}

.status-desc {
  margin-top: 12rpx;
  color: rgba(255, 255, 255, 0.72);
  font-size: 23rpx;
}

.status-icon {
  width: 56rpx;
  height: 56rpx;
  border: 4rpx solid #D8A84A;
  border-radius: 14rpx;
  color: #D8A84A;
  font-size: 24rpx;
  font-weight: 900;
  line-height: 48rpx;
  text-align: center;
  box-sizing: border-box;
}

.status-icon.pending {
  border-color: #D8A84A;
}

.status-icon.unused {
  border-color: #FF3D45;
  color: #FF3D45;
}

.verify-card {
  min-height: 186rpx;
  box-sizing: border-box;
  margin-top: -42rpx;
  padding: 24rpx;
  border-radius: 20rpx;
  background:
    radial-gradient(circle at 84% 36%, rgba(216, 168, 74, 0.18), transparent 26%),
    linear-gradient(135deg, #d81f2b, #9a141e);
  color: #ffffff;
  box-shadow: 0 12rpx 26rpx rgba(0, 0, 0, 0.12);
}

.verify-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  color: rgba(255, 255, 255, 0.82);
  font-size: 24rpx;
}

.table-no {
  color: #ffe2a1;
  font-weight: 800;
}

.verify-code {
  margin-top: 22rpx;
  color: #ffe2a1;
  font-size: 48rpx;
  font-weight: 900;
  letter-spacing: 0;
}

.verify-tip {
  margin-top: 14rpx;
  color: rgba(255, 255, 255, 0.72);
  font-size: 23rpx;
}

.white-card {
  margin-top: 22rpx;
  padding: 24rpx;
  border-radius: 20rpx;
  background: #ffffff;
}

.card-title {
  font-size: 30rpx;
  font-weight: 900;
}

.item-row {
  position: relative;
  min-height: 132rpx;
  box-sizing: border-box;
  margin-top: 22rpx;
  padding: 0 54rpx 0 130rpx;
}

.item-image {
  position: absolute;
  left: 0;
  top: 0;
  width: 108rpx;
  height: 108rpx;
  border-radius: 16rpx;
  background:
    radial-gradient(circle at 72% 24%, rgba(255, 255, 255, 0.35), transparent 20%),
    linear-gradient(135deg, #08103e, #8c1d2a 58%, #D8A84A);
}

.item-image.beer {
  background:
    radial-gradient(circle at 70% 20%, rgba(255, 255, 255, 0.4), transparent 20%),
    linear-gradient(135deg, #07123e, #9c6a16 55%, #f3c75a);
}

.item-image.snack-plate {
  background:
    radial-gradient(circle at 62% 28%, rgba(255, 255, 255, 0.28), transparent 22%),
    linear-gradient(135deg, #14183d, #8c4718 58%, #D8A84A);
}

.item-info {
  min-width: 0;
}

.item-name {
  font-size: 28rpx;
  font-weight: 900;
}

.item-desc {
  margin-top: 8rpx;
  color: #777777;
  font-size: 23rpx;
  line-height: 1.35;
}

.item-price {
  margin-top: 10rpx;
  color: #FF3D45;
  font-size: 30rpx;
  font-weight: 900;
}

.item-count {
  position: absolute;
  right: 0;
  top: 8rpx;
  color: #777777;
  font-size: 24rpx;
}

.amount-card {
  padding-bottom: 8rpx;
}

.amount-row,
.info-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 18rpx;
  color: #666666;
  font-size: 25rpx;
}

.amount-row.total {
  color: #111A33;
  font-size: 32rpx;
  font-weight: 900;
}

.gold-text {
  color: #D8A84A;
  font-weight: 900;
}

.timeline-row {
  position: relative;
  display: flex;
  min-height: 86rpx;
  margin-top: 22rpx;
}

.timeline-dot {
  width: 22rpx;
  height: 22rpx;
  flex: 0 0 22rpx;
  margin-top: 8rpx;
  border-radius: 50%;
  background: #d8d8d8;
}

.timeline-dot.active {
  background: #FF3D45;
  box-shadow: 0 0 0 8rpx rgba(255, 61, 69, 0.12);
}

.timeline-copy {
  flex: 1;
  min-width: 0;
  margin-left: 20rpx;
}

.timeline-label {
  font-size: 26rpx;
  font-weight: 800;
}

.timeline-value {
  margin-top: 8rpx;
  color: #777777;
  font-size: 23rpx;
}

.info-card {
  padding-bottom: 6rpx;
}

.info-row text:first-child {
  width: 140rpx;
  flex: 0 0 140rpx;
}

.info-row text:last-child {
  flex: 1;
  min-width: 0;
  text-align: right;
  color: #111A33;
}

.primary-button {
  width: 168rpx;
  height: 58rpx;
  margin: 24rpx 0 0 auto;
  padding: 0;
  border-radius: 29rpx;
  background: #FF3D45;
  color: #ffffff;
  font-size: 25rpx;
  font-weight: 800;
  line-height: 58rpx;
}

.primary-button::after {
  border: 0;
}
