.order-page {
  min-height: 100vh;
  box-sizing: border-box;
  padding: 0 28rpx 56rpx;
  background: #F5F5F5;
  color: #111A33;
}

.order-hero {
  height: 220rpx;
  margin: 0 -28rpx;
  padding: 42rpx 28rpx 0;
  box-sizing: border-box;
  background:
    radial-gradient(circle at 86% 18%, rgba(216, 168, 74, 0.18), transparent 24%),
    linear-gradient(180deg, #070b34, #13164F);
  color: #ffffff;
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
}

.hero-title {
  font-size: 40rpx;
  font-weight: 900;
}

.hero-subtitle {
  margin-top: 10rpx;
  color: rgba(255, 255, 255, 0.7);
  font-size: 24rpx;
}

.hero-icon {
  width: 56rpx;
  height: 56rpx;
  border: 4rpx solid #D8A84A;
  border-radius: 14rpx;
  color: #D8A84A;
  font-size: 24rpx;
  font-weight: 900;
  line-height: 48rpx;
  text-align: center;
  box-sizing: border-box;
}

.tab-card {
  display: grid;
  grid-template-columns: repeat(4, minmax(0, 1fr));
  gap: 12rpx;
  min-height: 86rpx;
  box-sizing: border-box;
  margin-top: -42rpx;
  padding: 14rpx;
  border-radius: 20rpx;
  background: #ffffff;
  box-shadow: 0 12rpx 26rpx rgba(0, 0, 0, 0.12);
}

.tab-item {
  height: 58rpx;
  border-radius: 29rpx;
  color: #666666;
  font-size: 24rpx;
  line-height: 58rpx;
  text-align: center;
}

.tab-item.active {
  background: #FF3D45;
  color: #ffffff;
  font-weight: 800;
}

.order-list {
  margin-top: 22rpx;
}

.order-card {
  min-height: 300rpx;
  box-sizing: border-box;
  margin-bottom: 20rpx;
  padding: 22rpx;
  border-radius: 20rpx;
  background: #ffffff;
}

.card-head,
.card-foot,
.order-body {
  display: flex;
  align-items: center;
}

.card-head,
.card-foot {
  justify-content: space-between;
}

.order-no {
  color: #777777;
  font-size: 23rpx;
}

.status {
  width: 104rpx;
  height: 38rpx;
  border-radius: 19rpx;
  font-size: 21rpx;
  line-height: 38rpx;
  text-align: center;
}

.status.unused {
  background: rgba(255, 61, 69, 0.12);
  color: #FF3D45;
}

.status.done {
  background: rgba(17, 26, 51, 0.08);
  color: #666666;
}

.status.pending {
  background: rgba(216, 168, 74, 0.2);
  color: #8b5d12;
}

.order-body {
  margin-top: 22rpx;
}

.order-image {
  position: relative;
  width: 112rpx;
  height: 112rpx;
  flex: 0 0 112rpx;
  border-radius: 16rpx;
  background:
    radial-gradient(circle at 72% 24%, rgba(255, 255, 255, 0.35), transparent 20%),
    linear-gradient(135deg, #08103e, #8c1d2a 58%, #D8A84A);
}

.order-image.beer {
  background:
    radial-gradient(circle at 70% 20%, rgba(255, 255, 255, 0.4), transparent 20%),
    linear-gradient(135deg, #07123e, #9c6a16 55%, #f3c75a);
}

.order-image.snack-plate {
  background:
    radial-gradient(circle at 62% 28%, rgba(255, 255, 255, 0.28), transparent 22%),
    linear-gradient(135deg, #14183d, #8c4718 58%, #D8A84A);
}

.image-chip {
  position: absolute;
  right: 12rpx;
  bottom: 12rpx;
  width: 32rpx;
  height: 32rpx;
  border: 5rpx solid #ffffff;
  border-radius: 50%;
  background: #FF3D45;
  box-sizing: border-box;
}

.order-info {
  flex: 1;
  min-width: 0;
  margin-left: 18rpx;
}

.order-title {
  font-size: 30rpx;
  font-weight: 900;
}

.order-meta,
.order-count {
  margin-top: 10rpx;
  color: #777777;
  font-size: 23rpx;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.card-foot {
  margin-top: 24rpx;
  padding-top: 18rpx;
  border-top: 1rpx solid #eeeeee;
}

.amount {
  color: #FF3D45;
  font-size: 34rpx;
  font-weight: 900;
}

.button-group {
  display: flex;
  align-items: center;
  justify-content: flex-end;
  gap: 12rpx;
}

.action-button,
.detail-button,
.rebuy-button {
  width: 112rpx;
  height: 50rpx;
  margin: 0;
  padding: 0;
  border-radius: 25rpx;
  font-size: 22rpx;
  line-height: 50rpx;
}

.action-button {
  background: #FF3D45;
  color: #ffffff;
  font-weight: 800;
}

.detail-button {
  border: 2rpx solid #D8A84A;
  background: #ffffff;
  color: #8b5d12;
}

.rebuy-button {
  border: 2rpx solid #FF3D45;
  background: #ffffff;
  color: #FF3D45;
  font-weight: 800;
}

.action-button::after,
.detail-button::after,
.rebuy-button::after {
  border: 0;
}

.empty-card {
  min-height: 360rpx;
  margin-top: 28rpx;
  border-radius: 20rpx;
  background: #ffffff;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}

.empty-icon {
  width: 56rpx;
  height: 56rpx;
  border: 4rpx solid #D8A84A;
  border-radius: 14rpx;
  color: #D8A84A;
  font-size: 24rpx;
  font-weight: 900;
  line-height: 48rpx;
  text-align: center;
  box-sizing: border-box;
}

.empty-title {
  margin-top: 18rpx;
  font-size: 30rpx;
  font-weight: 800;
}

.empty-text {
  margin-top: 10rpx;
  color: #777777;
  font-size: 24rpx;
}
