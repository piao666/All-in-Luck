<view class="order-page">
  <view class="order-hero">
    <view>
      <view class="hero-title">我的订单</view>
      <view class="hero-subtitle">查看演示订单状态与到店使用信息</view>
    </view>
    <view class="hero-icon">单</view>
  </view>

  <view class="tab-card">
    <view
      wx:for="{{tabs}}"
      wx:key="id"
      class="tab-item {{selectedTab === item.id ? 'active' : ''}}"
      data-id="{{item.id}}"
      bindtap="selectTab"
    >{{item.name}}</view>
  </view>

  <view class="order-list">
    <view
      wx:for="{{filteredOrders}}"
      wx:key="id"
      class="order-card"
      data-id="{{item.id}}"
      bindtap="goDetail"
    >
      <view class="card-head">
        <text class="order-no">{{item.id}}</text>
        <text class="status {{item.statusType}}">{{item.status}}</text>
      </view>
      <view class="order-body">
        <view class="order-image {{item.items[0].imageType}}">
          <view class="image-chip"></view>
        </view>
        <view class="order-info">
          <view class="order-title">{{item.title}}</view>
          <view class="order-meta">桌号 {{item.tableNo}} · {{item.orderTime}}</view>
          <view class="order-count">共 {{item.items.length}} 类商品 · 赠送 {{item.points}} 积分</view>
        </view>
      </view>
      <view class="card-foot">
        <view class="amount">¥{{item.totalAmount}}</view>
        <button
          wx:if="{{item.statusType !== 'done'}}"
          class="action-button"
          data-status="{{item.statusType}}"
          catchtap="handleAction"
        >{{item.statusType === 'pending' ? '去付款' : '去使用'}}</button>
        <button
          wx:else
          class="detail-button"
          data-id="{{item.id}}"
          catchtap="goDetail"
        >看详情</button>
      </view>
    </view>
  </view>

  <view wx:if="{{!filteredOrders.length}}" class="empty-card">
    <view class="empty-icon">单</view>
    <view class="empty-title">暂无订单</view>
    <view class="empty-text">当前分类没有演示订单</view>
  </view>
</view>
