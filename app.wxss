page {
  min-height: 100vh;
  background: #13164F;
  color: #ffffff;
  font-family: -apple-system, BlinkMacSystemFont, 'Helvetica Neue', Helvetica, Arial, sans-serif;
}

.page {
  min-height: 100vh;
  box-sizing: border-box;
  padding: 48rpx 32rpx;
}

.page-title {
  font-size: 40rpx;
  font-weight: 700;
  line-height: 1.4;
}

.page-subtitle {
  margin-top: 16rpx;
  color: rgba(255, 255, 255, 0.72);
  font-size: 26rpx;
}
